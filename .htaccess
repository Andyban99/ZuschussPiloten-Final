# ================================================
# ZUSCHUSS PILOTEN - SECURITY CONFIGURATION
# ================================================

# Enable Rewrite Engine
RewriteEngine On

# ================================================
# HTTPS & WWW REDIRECTS
# ================================================

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.zuschusspiloten\.de [NC]
RewriteRule ^(.*)$ https://zuschusspiloten.de/$1 [L,R=301]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ================================================
# LOGO REDIRECT
# ================================================

# Redirect /logo to the logo image
RewriteRule ^logo$ /assets/Zuschuss%20Piloten%20Logo%202.png [L,R=301]

# ================================================
# CLEAN URLs (ohne .html)
# ================================================

# Redirect .html URLs to clean URLs (except index.html)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteCond %{REQUEST_FILENAME} !praesentation\.html [NC]
RewriteRule ^ /%1 [R=301,L]

# Redirect /index to /
RewriteRule ^index$ / [R=301,L]

# Serve .html file for clean URL (no redirect, just internal rewrite)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# ================================================
# SECURITY HEADERS
# ================================================

<IfModule mod_headers.c>
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # XSS Protection
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

    # Strict Transport Security (HSTS) - 1 Jahr
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Content Security Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://code.iconify.design https://fonts.googleapis.com https://app.cal.eu; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.iconify.design https://app.cal.eu; frame-src 'self' https://app.cal.eu https://cal.eu https://www.cal.eu; frame-ancestors 'self';"

    # Remove server signature
    Header unset Server
    Header always unset X-Powered-By
</IfModule>

# ================================================
# DIRECTORY PROTECTION
# ================================================

# Disable directory listing
Options -Indexes

# Disable server signature
ServerSignature Off

# ================================================
# FILE ACCESS PROTECTION
# ================================================

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect config files
<FilesMatch "(config\.php|\.env|\.htpasswd|\.git|composer\.(json|lock))$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect backup files
<FilesMatch "\.(bak|backup|old|orig|save|swp|tmp)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect log files
<FilesMatch "\.log$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ================================================
# UPLOAD DIRECTORY PROTECTION
# ================================================

# Prevent PHP execution in uploads
<IfModule mod_rewrite.c>
    RewriteRule ^backend/uploads/.*\.php$ - [F,L]
</IfModule>

# ================================================
# RATE LIMITING (if mod_evasive is available)
# ================================================

<IfModule mod_evasive20.c>
    DOSHashTableSize 3097
    DOSPageCount 5
    DOSSiteCount 100
    DOSPageInterval 1
    DOSSiteInterval 1
    DOSBlockingPeriod 60
</IfModule>

# ================================================
# BOT & SPAM PROTECTION
# ================================================

# Block common bad bots
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_USER_AGENT} (bot|crawl|spider|slurp|fetch) [NC]
    RewriteCond %{HTTP_USER_AGENT} !(googlebot|bingbot|yandex|duckduckbot) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# Block empty user agents
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_USER_AGENT} ^$ [NC]
    RewriteCond %{REQUEST_URI} !^/backend/api/ [NC]
    RewriteRule .* - [F,L]
</IfModule>

# ================================================
# SQL INJECTION & XSS PROTECTION
# ================================================

<IfModule mod_rewrite.c>
    # Block SQL injection attempts
    RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} proc/self/environ [OR]
    RewriteCond %{QUERY_STRING} mosConfig_[a-zA-Z_]{1,21}(=|\%3D) [OR]
    RewriteCond %{QUERY_STRING} base64_(en|de)code[^(]*\([^)]*\) [OR]
    RewriteCond %{QUERY_STRING} (<|%3C)([^s]*s)+cript.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} UNION([^S]*S)+ELECT [NC,OR]
    RewriteCond %{QUERY_STRING} concat[^\(]*\( [NC,OR]
    RewriteCond %{QUERY_STRING} union([^s]*s)+elect [NC]
    RewriteRule .* - [F,L]
</IfModule>

# ================================================
# FILE UPLOAD RESTRICTIONS
# ================================================

# Limit upload size
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 60
    php_value max_input_time 60
</IfModule>

# ================================================
# COMPRESSION (for performance)
# ================================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# ================================================
# CACHING (for performance)
# ================================================

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType text/html "access plus 1 hour"
</IfModule>

# ================================================
# ERROR PAGES
# ================================================

ErrorDocument 400 /index.html
ErrorDocument 401 /index.html
ErrorDocument 403 /index.html
ErrorDocument 404 /index.html
ErrorDocument 500 /index.html
